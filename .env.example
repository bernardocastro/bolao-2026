# ── App ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NODE_ENV=development

# ── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://bolao:bolao_secret@localhost:5432/bolao2026?schema=public

# ── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret-min-32-characters!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-characters!
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# ── Google OAuth ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Realtime ───────────────────────────────────────────
SOCKET_PORT=3001
SOCKET_CORS_ORIGIN=http://localhost:3000

# ── Football data provider ─────────────────────────────
FOOTBALL_PROVIDER=espn        # mock | espn | api-football
# ESPN (free, no key needed):
ESPN_DATES_FROM=20260611      # start of WC 2026
ESPN_DATES_TO=20260720        # end of WC 2026
# api-football fallback (optional):
FOOTBALL_API_KEY=
FOOTBALL_API_BASE_URL=https://v3.football.api-sports.io

# ── Email (recuperação de senha) ───────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Bolão 2026 <no-reply@bolao2026.app>"
